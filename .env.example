# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env

# Django
DJANGO_SECRET_KEY=troque-por-uma-chave-forte
DJANGO_DEBUG=True

# Banco de dados (deixe vazio para usar SQLite local)
DB_HOST=
DB_NAME=ap2db
DB_USER=admin
DB_PASSWORD=
DB_PORT=3306

# AWS S3 (deixe vazio para armazenar mídia localmente)
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1

# Senha do admin criado no deploy (opcional)
DJANGO_ADMIN_PASSWORD=admin1234
